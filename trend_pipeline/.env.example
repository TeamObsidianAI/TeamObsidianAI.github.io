# Required: Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Optional: Override where the JSON report is written
# Default writes to ../trend-data.json (the website root, for the dashboard to read)
REPORT_OUTPUT_PATH=../trend-data.json

# Optional: comma-separated Amazon category slugs to scrape
# Default covers the most popular dropshipping categories
AMAZON_CATEGORIES=electronics,home-garden,toys-and-games,beauty,sporting-goods,pet-supplies
